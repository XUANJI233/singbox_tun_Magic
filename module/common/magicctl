#!/system/bin/sh

DATA_DIR="${SBMAGIC_DATA_DIR:-/data/adb/singbox_tun_Magic}"
BIN_DIR="$DATA_DIR/bin"
CONFIG_DIR="$DATA_DIR/configs"
RUNTIME_DIR="$DATA_DIR/runtime"
LOG_DIR="$DATA_DIR/logs"
CACHE_DIR="$DATA_DIR/cache"

CORE_BIN="$BIN_DIR/.core"
SING_BOX="$BIN_DIR/netd-helper"
FETCHER="$BIN_DIR/magic-fetch"
APPLIST_DEX="$BIN_DIR/applist.dex"
SETTINGS_FILE="$CONFIG_DIR/settings.env"
OUTBOUNDS_FILE="$CONFIG_DIR/outbounds.json"
EXCLUDE_FILE="$CONFIG_DIR/packages.exclude"
INCLUDE_FILE="$CONFIG_DIR/packages.include"
PROXY_PACKAGES_FILE="$CONFIG_DIR/packages.proxy"
FREE_FLOW_PACKAGES_FILE="$CONFIG_DIR/packages.free-flow"
DNS_DIRECT_FILE="$CONFIG_DIR/dns-direct-domains.txt"
CONFIG_FILE="$RUNTIME_DIR/config.json"
LAST_GOOD_FILE="$RUNTIME_DIR/config.last-good.json"
API_ENV_FILE="$RUNTIME_DIR/api.env"
PID_FILE="$RUNTIME_DIR/sing-box.pid"
PROCESS_FILE="$RUNTIME_DIR/process.path"
WATCHDOG_PID_FILE="$RUNTIME_DIR/watchdog.pid"
FAIL_COUNT_FILE="$RUNTIME_DIR/watchdog.failcount"
START_LOCK_DIR="$RUNTIME_DIR/start.lock"
CONFIG_LOCK_DIR="$RUNTIME_DIR/config.lock"
RUN_LOG="$LOG_DIR/sing-box.log"
CONTROL_LOG="$LOG_DIR/control.log"

# Consecutive watchdog-detected crashes within this many restart cycles
# before we give up restarting the rendered config and try last-good /
# disable instead. See watchdog() and rollback_service().
FAIL_THRESHOLD=3

mkdirs() {
  mkdir -p "$BIN_DIR" "$CONFIG_DIR" "$RUNTIME_DIR" "$LOG_DIR" "$CACHE_DIR"
}

log() {
  mkdirs
  echo "$(date '+%Y-%m-%d %H:%M:%S') $*" >> "$CONTROL_LOG"
}

die() {
  echo "ERROR: $*" >&2
  log "ERROR: $*"
  exit 1
}

load_settings_values() {
  SBMAGIC_ENABLED=true
  SBMAGIC_BOOT_START=false
  SBMAGIC_WATCHDOG=true
  SBMAGIC_WATCHDOG_INTERVAL=300
  SBMAGIC_STACK=gvisor
  SBMAGIC_PROCESS_NAME=netd-helper
  SBMAGIC_INTERFACE=utun0
  SBMAGIC_MTU=1400
  SBMAGIC_IPV6=false
  SBMAGIC_AUTO_ROUTE=true
  SBMAGIC_STRICT_ROUTE=true
  SBMAGIC_PACKAGE_MODE=black
  SBMAGIC_PROXY_RULE_MODE=bypass-cn
  SBMAGIC_FREE_FLOW_RULE_MODE=off
  SBMAGIC_MIXED_RULE_PRIORITY=proxy
  SBMAGIC_DNS_MODE=real-ip
  SBMAGIC_DNS_STRATEGY=ipv4_only
  SBMAGIC_DNS_LOCAL_TYPE=https
  SBMAGIC_DNS_LOCAL_SERVER=223.5.5.5
  SBMAGIC_DNS_REMOTE_TYPE=https
  SBMAGIC_DNS_REMOTE_SERVER=1.1.1.1
  SBMAGIC_DNS_FINAL=remote
  SBMAGIC_FAKEIP4=198.18.0.0/15
  SBMAGIC_FAKEIP6=fc00::/18
  SBMAGIC_API_HOST=127.0.0.1
  SBMAGIC_API_PORT=auto
  SBMAGIC_API_FIREWALL=true
  SBMAGIC_API_MODE=Rule
  SBMAGIC_RULESET_DOWNLOAD_DETOUR=proxy
  SBMAGIC_RULE_UPDATE_INTERVAL=168h

  if [ -f "$SETTINGS_FILE" ]; then
    # shellcheck disable=SC1090
    . "$SETTINGS_FILE"
  fi
}

load_settings() {
  load_settings_values
  set_process_binary_path
  validate_interface_name
  validate_settings
}

set_process_binary_path() {
  case "$SBMAGIC_PROCESS_NAME" in
    ""|"."|".."|*/*|*\\*|*[!A-Za-z0-9._-]*)
      die "invalid SBMAGIC_PROCESS_NAME: use only A-Z a-z 0-9 . _ -"
      ;;
  esac
  SING_BOX="$BIN_DIR/$SBMAGIC_PROCESS_NAME"
}

set_process_binary_path_relaxed() {
  case "$SBMAGIC_PROCESS_NAME" in
    ""|"."|".."|*/*|*\\*|*[!A-Za-z0-9._-]*)
      saved_process="$(cat "$PROCESS_FILE" 2>/dev/null)"
      SING_BOX="${saved_process:-$BIN_DIR/netd-helper}"
      return 1
      ;;
  esac
  SING_BOX="$BIN_DIR/$SBMAGIC_PROCESS_NAME"
  return 0
}

validate_interface_name() {
  case "$SBMAGIC_INTERFACE" in
    ""|*/*|*\\*|*[!A-Za-z0-9._-]*)
      die "invalid SBMAGIC_INTERFACE: use only A-Z a-z 0-9 . _ -"
      ;;
  esac
  [ "${#SBMAGIC_INTERFACE}" -le 15 ] || die "invalid SBMAGIC_INTERFACE: Linux interface names must be 15 bytes or shorter"
}

validate_one_of() {
  value="$1"
  name="$2"
  shift 2
  for allowed in "$@"; do
    [ "$value" = "$allowed" ] && return 0
  done
  die "invalid $name '$value': use one of: $*"
}

validate_uint_range() {
  value="$1"
  name="$2"
  min="$3"
  max="$4"
  case "$value" in
    ''|*[!0-9]*) die "invalid $name '$value': use an integer from $min to $max" ;;
  esac
  [ "$value" -ge "$min" ] && [ "$value" -le "$max" ] || die "invalid $name '$value': use an integer from $min to $max"
}

validate_dns_server_literal() {
  value="$1"
  name="$2"
  case "$value" in
    ''|*://*|*/*|*[!0-9A-Fa-f:.]*)
      die "invalid $name '$value': use an IP literal, not a hostname or URL"
      ;;
  esac
}

validate_settings() {
  json_bool "$SBMAGIC_ENABLED" >/dev/null
  json_bool "$SBMAGIC_BOOT_START" >/dev/null
  json_bool "$SBMAGIC_WATCHDOG" >/dev/null
  json_bool "$SBMAGIC_IPV6" >/dev/null
  json_bool "$SBMAGIC_AUTO_ROUTE" >/dev/null
  json_bool "$SBMAGIC_STRICT_ROUTE" >/dev/null
  json_bool "$SBMAGIC_API_FIREWALL" >/dev/null

  validate_uint_range "$SBMAGIC_WATCHDOG_INTERVAL" SBMAGIC_WATCHDOG_INTERVAL 60 86400
  validate_uint_range "$SBMAGIC_MTU" SBMAGIC_MTU 1200 9000
  validate_one_of "$SBMAGIC_STACK" SBMAGIC_STACK gvisor system mixed
  validate_one_of "$SBMAGIC_PACKAGE_MODE" SBMAGIC_PACKAGE_MODE black white
  validate_one_of "$SBMAGIC_PROXY_RULE_MODE" SBMAGIC_PROXY_RULE_MODE off global bypass-cn
  validate_one_of "$SBMAGIC_FREE_FLOW_RULE_MODE" SBMAGIC_FREE_FLOW_RULE_MODE off global
  validate_one_of "$SBMAGIC_MIXED_RULE_PRIORITY" SBMAGIC_MIXED_RULE_PRIORITY proxy free-flow
  validate_one_of "$SBMAGIC_DNS_MODE" SBMAGIC_DNS_MODE real-ip fake-ip
  validate_one_of "$SBMAGIC_DNS_STRATEGY" SBMAGIC_DNS_STRATEGY ipv4_only prefer_ipv4 prefer_ipv6 ipv6_only
  validate_one_of "$SBMAGIC_DNS_LOCAL_TYPE" SBMAGIC_DNS_LOCAL_TYPE https tls quic h3 udp tcp
  validate_one_of "$SBMAGIC_DNS_REMOTE_TYPE" SBMAGIC_DNS_REMOTE_TYPE https tls quic h3 udp tcp
  validate_one_of "$SBMAGIC_DNS_FINAL" SBMAGIC_DNS_FINAL remote local
  validate_one_of "$SBMAGIC_API_MODE" SBMAGIC_API_MODE Rule Global Direct
  validate_one_of "$SBMAGIC_RULESET_DOWNLOAD_DETOUR" SBMAGIC_RULESET_DOWNLOAD_DETOUR proxy direct
  validate_dns_server_literal "$SBMAGIC_DNS_LOCAL_SERVER" SBMAGIC_DNS_LOCAL_SERVER
  validate_dns_server_literal "$SBMAGIC_DNS_REMOTE_SERVER" SBMAGIC_DNS_REMOTE_SERVER
}

cleanup_stale_process_binaries() {
  [ -f "$CORE_BIN" ] || return 0
  for candidate in "$BIN_DIR"/* "$BIN_DIR"/.[!.]* "$BIN_DIR"/..?*; do
    [ -e "$candidate" ] || continue
    case "$candidate" in
      "$CORE_BIN"|"$SING_BOX"|"$FETCHER"|"$APPLIST_DEX")
        continue
      ;;
    esac
    [ -f "$candidate" ] || continue
    if same_file "$CORE_BIN" "$candidate" || same_file_fingerprint "$CORE_BIN" "$candidate"; then
      rm -f "$candidate"
    fi
  done
}

same_file() {
  [ "$1" -ef "$2" ] 2>/dev/null
}

file_fingerprint() {
  stat -c '%s:%Y' "$1" 2>/dev/null
}

same_file_fingerprint() {
  fp_a="$(file_fingerprint "$1")"
  fp_b="$(file_fingerprint "$2")"
  [ -n "$fp_a" ] && [ "$fp_a" = "$fp_b" ]
}

process_binary_fresh() {
  [ -x "$SING_BOX" ] || return 1
  same_file "$CORE_BIN" "$SING_BOX" && return 0
  core_fp="$(file_fingerprint "$CORE_BIN")"
  process_fp="$(file_fingerprint "$SING_BOX")"
  [ -n "$core_fp" ] && [ "$core_fp" = "$process_fp" ]
}

prepare_process_binary() {
  mkdirs
  set_process_binary_path
  [ -x "$CORE_BIN" ] || die "core binary missing: $CORE_BIN"
  if [ "$SING_BOX" != "$CORE_BIN" ]; then
    if ! process_binary_fresh; then
      tmp="$RUNTIME_DIR/process-bin.$$"
      rm -f "$tmp"
      ln "$CORE_BIN" "$tmp" 2>/dev/null || cp -p "$CORE_BIN" "$tmp" 2>/dev/null || cp -f "$CORE_BIN" "$tmp" || {
        rm -f "$tmp"
        die "failed to prepare process binary: $SING_BOX"
      }
      chmod 755 "$tmp"
      mv -f "$tmp" "$SING_BOX" || {
        rm -f "$tmp"
        die "failed to install process binary: $SING_BOX"
      }
    fi
    cleanup_stale_process_binaries
  fi
}

iptables_run() {
  bin="$1"
  shift
  "$bin" -w "$@" 2>/dev/null || "$bin" "$@" 2>/dev/null
}

remove_api_firewall() {
  command -v iptables >/dev/null 2>&1 || return 0
  while iptables_run iptables -D OUTPUT -j SBMAGIC_API; do :; done
  iptables_run iptables -F SBMAGIC_API || true
  iptables_run iptables -X SBMAGIC_API || true
}

apply_api_firewall() {
  if [ "$(json_bool "$SBMAGIC_API_FIREWALL")" != "true" ]; then
    remove_api_firewall
    return 0
  fi
  [ "$SBMAGIC_API_HOST" = "127.0.0.1" ] || { log "api firewall skipped: non-loopback host $SBMAGIC_API_HOST"; return 0; }
  valid_port "$SBMAGIC_API_PORT" || { log "api firewall skipped: invalid port $SBMAGIC_API_PORT"; return 0; }
  command -v iptables >/dev/null 2>&1 || { log "api firewall skipped: iptables unavailable"; return 0; }

  remove_api_firewall
  iptables_run iptables -N SBMAGIC_API || { log "api firewall skipped: cannot create chain"; return 0; }
  if ! iptables_run iptables -A SBMAGIC_API -p tcp -d 127.0.0.1 --dport "$SBMAGIC_API_PORT" -m owner --uid-owner 0 -j RETURN; then
    log "api firewall skipped: owner match unavailable"
    remove_api_firewall
    return 0
  fi
  iptables_run iptables -A SBMAGIC_API -p tcp -d 127.0.0.1 --dport "$SBMAGIC_API_PORT" -m owner --uid-owner 2000 -j RETURN || true
  iptables_run iptables -A SBMAGIC_API -p tcp -d 127.0.0.1 --dport "$SBMAGIC_API_PORT" -j REJECT || {
    log "api firewall skipped: reject rule failed"
    remove_api_firewall
    return 0
  }
  iptables_run iptables -I OUTPUT 1 -j SBMAGIC_API || {
    log "api firewall skipped: cannot attach chain"
    remove_api_firewall
    return 0
  }
  log "api firewall active on 127.0.0.1:$SBMAGIC_API_PORT"
}

json_bool() {
  case "$1" in
    true) echo true ;;
    false|"") echo false ;;
    *) die "invalid boolean '$1': use true or false" ;;
  esac
}

json_array_from_file() {
  file="$1"
  awk '
    BEGIN { first = 1; printf "[" }
    {
      line = $0
      sub(/\r$/, "", line)
      sub(/^[ \t]+/, "", line)
      sub(/[ \t]+$/, "", line)
      if (line == "" || line ~ /^#/) next
      gsub(/\\/, "\\\\", line)
      gsub(/"/, "\\\"", line)
      if (!first) printf ","
      printf "\"%s\"", line
      first = 0
    }
    END { printf "]" }
  ' "$file"
}

package_file_has_entries() {
  file="$1"
  awk '
    {
      line = $0
      sub(/\r$/, "", line)
      sub(/^[ \t]+/, "", line)
      sub(/[ \t]+$/, "", line)
      if (line != "" && line !~ /^#/) found = 1
    }
    END { exit(found ? 0 : 1) }
  ' "$file" 2>/dev/null
}

first_package_conflict_files() {
  proxy_file="$1"
  free_flow_file="$2"
  awk '
    FNR == NR {
      line = $0
      sub(/\r$/, "", line)
      sub(/^[ \t]+/, "", line)
      sub(/[ \t]+$/, "", line)
      if (line != "" && line !~ /^#/) seen[line] = 1
      next
    }
    {
      line = $0
      sub(/\r$/, "", line)
      sub(/^[ \t]+/, "", line)
      sub(/[ \t]+$/, "", line)
      if (line != "" && line !~ /^#/ && seen[line]) {
        print line
        exit
      }
    }
  ' "$proxy_file" "$free_flow_file" 2>/dev/null
}

first_package_conflict() {
  first_package_conflict_files "$PROXY_PACKAGES_FILE" "$FREE_FLOW_PACKAGES_FILE"
}

ensure_no_strategy_conflicts() {
  conflict="$(first_package_conflict)"
  [ -z "$conflict" ] || die "package exists in both packages.proxy and packages.free-flow: $conflict"
}

ensure_no_strategy_conflicts_files() {
  conflict="$(first_package_conflict_files "$1" "$2")"
  [ -z "$conflict" ] || die "package exists in both packages.proxy and packages.free-flow: $conflict"
}

route_package_field() {
  package_arr="$1"
  [ -n "$package_arr" ] || return 0
  printf ',\n        "package_name": %s' "$package_arr"
}

route_proxy_rules() {
  package_arr="$1"
  [ "$package_arr" = "[]" ] && return 0
  pkg_json="$(route_package_field "$package_arr")"
  case "$SBMAGIC_PROXY_RULE_MODE" in
    off)
      return 0
      ;;
    global)
      cat <<EOF
,
      {
        "outbound": "proxy"$pkg_json
      }
EOF
      ;;
    bypass-cn)
      cat <<EOF
,
      {
        "domain_suffix": [
          "cn"
        ],
        "outbound": "direct"$pkg_json
      },
      {
        "rule_set": [
          "geosite-cn",
          "geoip-cn"
        ],
        "outbound": "direct"$pkg_json
      },
      {
        "outbound": "proxy"$pkg_json
      }
EOF
      ;;
  esac
}

route_free_flow_rules() {
  package_arr="$1"
  [ "$package_arr" = "[]" ] && return 0
  pkg_json="$(route_package_field "$package_arr")"
  case "$SBMAGIC_FREE_FLOW_RULE_MODE" in
    off)
      return 0
      ;;
    global)
      cat <<EOF
,
      {
        "outbound": "free-flow"$pkg_json
      }
EOF
      ;;
  esac
}

route_mixed_rules() {
  case "$SBMAGIC_MIXED_RULE_PRIORITY" in
    free-flow)
      route_free_flow_rules ""
      route_proxy_rules ""
      ;;
    *)
      route_proxy_rules ""
      route_free_flow_rules ""
      ;;
  esac
}

random_token() {
  token=""
  if command -v od >/dev/null 2>&1; then
    token="$(od -An -N24 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n')"
  fi
  if [ -z "$token" ]; then
    token="$(date +%s)$$"
  fi
  echo "$token"
}

random_api_port() {
  n=""
  if command -v od >/dev/null 2>&1; then
    n="$(od -An -N2 -tu2 /dev/urandom 2>/dev/null | tr -d ' \n')"
  fi
  case "$n" in ''|*[!0-9]*) n="$(date +%s)" ;; esac
  # Stay BELOW the Linux ephemeral range (ip_local_port_range is 32768-60999 on
  # Android). A persisted random port that overlapped the ephemeral range could
  # one day collide with a transient socket at boot, the clash_api bind would
  # fail, and the watchdog would keep retrying the same dead port. 20000-31999
  # avoids that window entirely.
  echo $((20000 + (n % 12000)))
}

valid_port() {
  case "$1" in
    ''|*[!0-9]*) return 1 ;;
  esac
  [ "$1" -ge 1 ] && [ "$1" -le 65535 ]
}

write_api_env() {
  {
    echo "SBMAGIC_API_SECRET=$SBMAGIC_API_SECRET"
    echo "SBMAGIC_API_PORT=$SBMAGIC_API_PORT"
  } > "$API_ENV_FILE"
  chmod 600 "$API_ENV_FILE"
}

ensure_api_env() {
  mkdirs
  configured_port="$SBMAGIC_API_PORT"
  if [ -f "$API_ENV_FILE" ]; then
    # shellcheck disable=SC1090
    . "$API_ENV_FILE"
  fi
  rewrite_api_env=false
  if [ -z "$SBMAGIC_API_SECRET" ]; then
    SBMAGIC_API_SECRET="$(random_token)"
    rewrite_api_env=true
  fi
  case "$configured_port" in
    auto|AUTO|"")
      if ! valid_port "$SBMAGIC_API_PORT"; then
        SBMAGIC_API_PORT="$(random_api_port)"
        rewrite_api_env=true
      fi
      ;;
    *)
      valid_port "$configured_port" || die "invalid SBMAGIC_API_PORT '$configured_port': use auto or a port from 1 to 65535"
      SBMAGIC_API_PORT="$configured_port"
      ;;
  esac
  $rewrite_api_env && write_api_env
}

pid_alive() {
  [ -f "$PID_FILE" ] || return 1
  pid="$(cat "$PID_FILE" 2>/dev/null)"
  [ -n "$pid" ] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  cmdline="$(tr '\000' ' ' < "/proc/$pid/cmdline" 2>/dev/null)"
  saved_process="$(cat "$PROCESS_FILE" 2>/dev/null)"
  case "$cmdline" in
    *"$SING_BOX"*) return 0 ;;
  esac
  if [ -n "$saved_process" ]; then
    case "$cmdline" in
      *"$saved_process"*) return 0 ;;
    esac
  fi
  return 1
}

watchdog_alive() {
  [ -f "$WATCHDOG_PID_FILE" ] || return 1
  wpid="$(cat "$WATCHDOG_PID_FILE" 2>/dev/null)"
  [ -n "$wpid" ] || return 1
  kill -0 "$wpid" 2>/dev/null || return 1
  cmdline="$(tr '\000' ' ' < "/proc/$wpid/cmdline" 2>/dev/null)"
  case "$cmdline" in
    *"magicctl"*"watchdog"*) return 0 ;;
    *) return 1 ;;
  esac
}

package_field() {
  mode="$SBMAGIC_PACKAGE_MODE"
  case "$mode" in
    white)
      arr="$(json_array_from_file "$INCLUDE_FILE")"
      printf ',\n      "include_package": %s' "$arr"
      ;;
    *)
      arr="$(json_array_from_file "$EXCLUDE_FILE")"
      printf ',\n      "exclude_package": %s' "$arr"
      ;;
  esac
}

tun_stack_fields() {
  # sing-box documents endpoint_independent_nat as gvisor-only; other stacks
  # already use endpoint-independent NAT by default.
  if [ "$SBMAGIC_STACK" = "gvisor" ]; then
    printf ',\n      "endpoint_independent_nat": true'
  fi
  printf ',\n      "udp_timeout": "5m"'
}

render_config() {
  mkdirs
  load_settings
  prepare_process_binary
  ensure_api_env

  [ -x "$SING_BOX" ] || die "sing-box binary missing: $SING_BOX"
  [ -f "$OUTBOUNDS_FILE" ] || die "outbounds file missing: $OUTBOUNDS_FILE"
  ensure_no_strategy_conflicts

  auto_route="$(json_bool "$SBMAGIC_AUTO_ROUTE")"
  strict_route="$(json_bool "$SBMAGIC_STRICT_ROUTE")"
  ipv6_enabled="$(json_bool "$SBMAGIC_IPV6")"
  package_json="$(package_field)"
  tun_stack_json="$(tun_stack_fields)"
  dns_direct_domains="$(json_array_from_file "$DNS_DIRECT_FILE")"
  proxy_packages="$(json_array_from_file "$PROXY_PACKAGES_FILE")"
  free_flow_packages="$(json_array_from_file "$FREE_FLOW_PACKAGES_FILE")"
  forced_proxy_rules="$(route_proxy_rules "$proxy_packages")"
  forced_free_flow_rules="$(route_free_flow_rules "$free_flow_packages")"
  mixed_rules="$(route_mixed_rules)"

  # The tun interface always claims a (non-routable ULA) IPv6 address so
  # auto_route grabs the IPv6 default route too -- even when SBMAGIC_IPV6 is
  # off. Without this, a device with real IPv6 connectivity would let
  # proxied apps' IPv6 traffic bypass the tun entirely and leak the real
  # address over the carrier network instead of being blocked/proxied.
  # See dns_reject_aaaa / route_ipv6_guard below for the "off" half of
  # this leak-prevention pair.
  tun_address='["172.19.0.1/30","fdfe:dcba:9876::1/126"]'

  dns_reject_aaaa=""
  route_ipv6_guard=""
  if [ "$ipv6_enabled" != "true" ]; then
    dns_reject_aaaa=$(cat <<'EOF'
{
        "query_type": [
          "AAAA"
        ],
        "action": "reject"
      },
EOF
)
    route_ipv6_guard=$(cat <<'EOF'
{
        "ip_version": 6,
        "action": "reject"
      },
EOF
)
  fi

  # fake-ip is expressed as a DNS *server* of type "fakeip" in the 1.12+
  # format (the old top-level dns.fakeip object was removed in 1.14). When
  # enabled we add that server and point dns.final at it so every non-direct
  # domain gets a fake address; direct/CN domains are still routed to the
  # real "local" resolver by the rules below.
  fakeip_server=""
  fakeip_rule=""
  # store_fakeip persists fake-ip<->domain mappings across restarts. Its
  # default flipped between sing-box versions, so we set it explicitly (only
  # in fake-ip mode) to keep behaviour predictable -- without it, every
  # restart invalidates live fake-ip sessions.
  store_fakeip_line=""
  if [ "$SBMAGIC_DNS_MODE" = "fake-ip" ]; then
    store_fakeip_line=',
      "store_fakeip": true'
    if [ "$ipv6_enabled" = "true" ]; then
      fakeip_query_types='"A","AAAA"'
      fakeip_server=$(cat <<EOF
,
      {
        "type": "fakeip",
        "tag": "fakeip",
        "inet4_range": "$SBMAGIC_FAKEIP4",
        "inet6_range": "$SBMAGIC_FAKEIP6"
      }
EOF
)
    else
      fakeip_query_types='"A"'
      fakeip_server=$(cat <<EOF
,
      {
        "type": "fakeip",
        "tag": "fakeip",
        "inet4_range": "$SBMAGIC_FAKEIP4"
      }
EOF
)
    fi
    fakeip_rule=$(cat <<EOF
,
      {
        "query_type": [
          $fakeip_query_types
        ],
        "action": "route",
        "server": "fakeip"
      }
EOF
)
  fi

  outbounds_json="$(cat "$OUTBOUNDS_FILE")"
  # PID-suffixed temp so two concurrent renders (e.g. a manual restart racing
  # the watchdog) can never clobber each other's half-written file -- each
  # writes a complete file and the final atomic mv just picks a winner.
  tmp="$CONFIG_FILE.tmp.$$"

  cat > "$tmp" <<EOF
{
  "log": {
    "level": "warn",
    "output": "$LOG_DIR/box.log",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "type": "$SBMAGIC_DNS_LOCAL_TYPE",
        "tag": "local",
