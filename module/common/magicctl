#!/system/bin/sh

DATA_DIR="${SBMAGIC_DATA_DIR:-/data/adb/singbox_tun_Magic}"
BIN_DIR="$DATA_DIR/bin"
CONFIG_DIR="$DATA_DIR/configs"
RUNTIME_DIR="$DATA_DIR/runtime"
LOG_DIR="$DATA_DIR/logs"
CACHE_DIR="$DATA_DIR/cache"
RULESET_DIR="$CACHE_DIR/rulesets"

CORE_BIN="$BIN_DIR/.core"
SING_BOX="$BIN_DIR/netd-helper"
FETCHER="$BIN_DIR/magic-fetch"
RENDERER="$BIN_DIR/magicctl-go"
APPLIST_DEX="$BIN_DIR/applist.dex"
SETTINGS_FILE="$CONFIG_DIR/settings.env"
OUTBOUNDS_FILE="$CONFIG_DIR/outbounds.json"
EXCLUDE_FILE="$CONFIG_DIR/packages.exclude"
INCLUDE_FILE="$CONFIG_DIR/packages.include"
PROXY_PACKAGES_FILE="$CONFIG_DIR/packages.proxy"
FREE_FLOW_PACKAGES_FILE="$CONFIG_DIR/packages.free-flow"
DNS_DIRECT_FILE="$CONFIG_DIR/dns-direct-domains.txt"
GEOSITE_CN_RULESET="$RULESET_DIR/geosite-cn.srs"
GEOIP_CN_RULESET="$RULESET_DIR/geoip-cn.srs"
GEOSITE_CN_RULESET_URL="https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/cn.srs"
GEOIP_CN_RULESET_URL="https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geoip/cn.srs"
CONFIG_FILE="$RUNTIME_DIR/config.json"
LAST_GOOD_FILE="$RUNTIME_DIR/config.last-good.json"
API_ENV_FILE="$RUNTIME_DIR/api.env"
PID_FILE="$RUNTIME_DIR/sing-box.pid"
PROCESS_FILE="$RUNTIME_DIR/process.path"
WATCHDOG_PID_FILE="$RUNTIME_DIR/watchdog.pid"
NETWATCH_PID_FILE="$RUNTIME_DIR/netwatch.pid"
NETWATCH_MONITOR_PID_FILE="$RUNTIME_DIR/netwatch.monitor.pid"
NETWATCH_IGNORE_UNTIL_FILE="$RUNTIME_DIR/netwatch.ignore-until"
NETWATCH_IGNORE_LOGGED_FILE="$RUNTIME_DIR/netwatch.ignore-logged"
NETWATCH_IPV6_ADDR_STATE_FILE="$RUNTIME_DIR/netwatch.ipv6-addrs"
IPV6_STATE_FILE="$RUNTIME_DIR/ipv6.state"
LAST_GOOD_PROMOTE_PID_FILE="$RUNTIME_DIR/last-good-promote.pid"
FAIL_COUNT_FILE="$RUNTIME_DIR/watchdog.failcount"
SUPERVISOR_RESTART_FILE="$RUNTIME_DIR/supervisor.restart"
SUPERVISOR_ROLLBACK_FILE="$RUNTIME_DIR/supervisor.rollback"
INITD_SEEN_FILE="$RUNTIME_DIR/initd.seen"
START_LOCK_DIR="$RUNTIME_DIR/start.lock"
CONFIG_LOCK_DIR="$RUNTIME_DIR/config.lock"
WATCHDOG_LOCK_DIR="$RUNTIME_DIR/watchdog.lock"
RUN_LOG="$LOG_DIR/sing-box.log"
CONTROL_LOG="$LOG_DIR/control.log"
CORE_VERSION_FILE="$RUNTIME_DIR/core.version"
PRECHECKED_CONFIG_FILE="$RUNTIME_DIR/config.prechecked"
ANDROID_PACKAGES_XML="/data/system/packages.xml"

# Consecutive watchdog-detected crashes within this many restart cycles
# before we give up restarting the rendered config and try last-good /
# disable instead. See watchdog() and rollback_service().
FAIL_THRESHOLD=3
API_CONNECT_TIMEOUT=1
API_MAX_TIME=2
API_RETRIES=1
NETWATCH_OWN_TUN_GRACE_SECONDS=12
case "$0" in
  */*) SBMAGIC_SELF_DIR="${0%/*}" ;;
  *) SBMAGIC_SELF_DIR="$DATA_DIR" ;;
esac
LIB_DIR="${SBMAGIC_LIB_DIR:-$SBMAGIC_SELF_DIR/lib}"

for lib in \
  base settings_defaults settings_runtime validators settings_validate process \
  firewall packages rulesets ipv6 api_env render locks service_start service_stop \
  service_reload status api health netwatch supervisor config_files \
  config_per_app init; do
  lib_file="$LIB_DIR/$lib.sh"
  if [ ! -f "$lib_file" ]; then
    echo "ERROR: magicctl library missing: $lib_file" >&2
    exit 1
  fi
  # shellcheck disable=SC1090
  . "$lib_file"
done
usage() {
  cat <<EOF
Usage: magicctl <command>

Commands:
  boot                 Start at boot and launch watchdog when enabled
  boot-dispatch        Prefer init service, then fall back to direct boot
  start                Render, check, and start sing-box
  stop                 Stop sing-box and the watchdog (stays stopped until start/boot)
  restart              Stop then start
  reload               Validate new config first, then restart (safe apply)
  render               Render runtime config
  check                Render and run sing-box check
  status               Show module and API status
  logs [run|box|control] [lines]
  enable               Set SBMAGIC_ENABLED=true
  disable              Set SBMAGIC_ENABLED=false and stop
  rollback             Stop, restore last-good config, and start it directly
  recover              Check local health and recover stale runtime connections
  api METHOD PATH [JSON]
  fetch URL              Fetch a subscription URL and print the body
  ruleset-refresh        Download local rule-sets and safe-reload when active
  config get KEY        Print a config file (settings|outbounds|exclude|include|proxy-packages|free-flow-packages|dns-direct)
  config set KEY        Overwrite a config file from stdin (keeps KEY.bak)
  config set-strategies Overwrite proxy/free-flow package strategy files atomically
  config set-per-app    Overwrite per-app mode and package files atomically
  config rollback KEY    Swap a config file with its .bak (toggle)
  applist [user|system]  List installed apps as "package\tlabel\tuser|system"
  watchdog             Event-driven supervisor with crash-loop guard
  netwatch             Event-driven network change monitor
  initd                Entry point for Android init service
EOF
}

cmd="$1"
shift 2>/dev/null || true

case "$cmd" in
  boot) boot ;;
  boot-dispatch) boot_dispatch ;;
  start) start_service ;;
  stop) stop_all_service ;;
  restart) restart_service ;;
  reload) reload_service ;;
  render) render_config ;;
  check) check_config ;;
  status) status ;;
  logs) logs "$1" "$2" ;;
  enable) enable_service ;;
  disable) disable_service ;;
  rollback) rollback_service ;;
  recover) recover_service ;;
  api) api_call "$1" "$2" "$3" ;;
  fetch) fetch_url "$1" ;;
  ruleset-refresh|geoupdate) ruleset_refresh ;;
  config)
    sub="$1"
    shift 2>/dev/null || true
    case "$sub" in
      get) config_get "$1" ;;
      set) config_set "$1" ;;
      set-strategies) config_set_strategy_packages ;;
      set-per-app) config_set_per_app ;;
      rollback) config_rollback "$1" ;;
      *) usage; exit 1 ;;
    esac
    ;;
  applist) applist "$1" ;;
  promote-last-good) promote_last_good_after "$1" "$2" "$3" ;;
  watchdog) watchdog ;;
  netwatch) netwatch ;;
  initd) initd ;;
  ""|-h|--help|help) usage ;;
  *) usage; exit 1 ;;
esac
