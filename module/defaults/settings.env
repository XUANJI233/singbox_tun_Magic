# Runtime switches use explicit true/false values.
SBMAGIC_ENABLED=true
SBMAGIC_BOOT_START=false
SBMAGIC_INIT_SERVICE=true
SBMAGIC_WATCHDOG=true
SBMAGIC_WATCHDOG_INTERVAL=300

# Event-driven recovery after Android network changes (resume from sleep,
# Wi-Fi/cellular switch, route refresh). This blocks in "ip monitor" and does
# not wake the device on a timer. By default it only restarts when the local API
# is unhealthy; it does NOT close healthy long-lived connections. Enable
# SBMAGIC_NETWORK_CHANGE_FLUSH only if a device repeatedly keeps stale
# transport sessions after real network switches.
SBMAGIC_NETWORK_WATCH=true
SBMAGIC_NETWORK_CHANGE_FLUSH=false
SBMAGIC_NETWORK_RECOVERY_COOLDOWN=30

# Optional low-memory protection. This writes /proc/<pid>/oom_score_adj for
# the core and its supervisor. Keep it off unless the device actually kills
# the process while idle.
SBMAGIC_OOM_PROTECT=false
SBMAGIC_OOM_SCORE_ADJ=-900

# TUN defaults: gvisor was the reliable Android CLI/root path in AVD tests.
SBMAGIC_STACK=gvisor
# Runtime binary basename. Change this if a target app keys off a known process
# name; allowed characters: A-Z a-z 0-9 . _ -
SBMAGIC_PROCESS_NAME=netd-helper
SBMAGIC_INTERFACE=utun0
SBMAGIC_MTU=1400
SBMAGIC_AUTO_ROUTE=true
# auto_redirect uses in-kernel nftables to forward IPv4 TCP without going through
# the userspace (gvisor) stack -- the single biggest throughput/CPU win for
# proxied and direct-split traffic. Requires auto_route + nftables; UDP and IPv6
# still use the configured stack. Keep on unless a device lacks nftables.
SBMAGIC_AUTO_REDIRECT=true
SBMAGIC_STRICT_ROUTE=true
# Full Cone NAT (endpoint_independent_nat) improves P2P/voice/gaming NAT
# traversal but sing-box documents it as a slight throughput cost (gvisor only).
# Off by default for the performance-first always-on profile; turn on only if
# you actually need Full Cone.
SBMAGIC_ENDPOINT_INDEPENDENT_NAT=false
# Android auto_redirect only accelerates IPv4 TCP. If a device is CPU-bound on
# app-side HTTP/3/QUIC, this optional switch rejects public UDP/443 so browsers
# and most apps fall back to TCP and can use the fast path. Keep it off by
# default because QUIC can be faster on lossy mobile networks; sing-box's own
# Hysteria2/TUIC/QUIC outbound sockets are not affected.
SBMAGIC_REJECT_QUIC=false

# Routing policy after an app has entered TUN. Default bypass-cn keeps selected
# proxy apps split by destination while non-selected apps stay out of TUN.
# For maximum proxy-app throughput, set global so selected apps skip CN rule-set
# matching and go to proxy except LAN/private direct.
# proxy: off | global | bypass-cn
# free-flow: off | global
# mixed priority applies to apps that are in neither packages.proxy nor
# packages.free-flow.
SBMAGIC_PROXY_RULE_MODE=bypass-cn
SBMAGIC_FREE_FLOW_RULE_MODE=off
SBMAGIC_MIXED_RULE_PRIORITY=proxy

# IPv6 leak protection: the tun always claims the IPv6 default route
# regardless of this switch (magicctl render_config), so disabling it
# does not mean "ignore IPv6" -- it means "block proxied apps' real
# IPv6 traffic instead of letting it bypass the proxy over the carrier
# network". Turning this on also requires changing SBMAGIC_DNS_STRATEGY
# away from ipv4_only (e.g. to prefer_ipv4) before AAAA records are
# actually resolved -- the WebUI settings tab explains this next to the
# toggle.
SBMAGIC_IPV6=false

# Package mode:
# black = proxy everything except packages listed in packages.exclude
# white = only proxy packages listed in packages.include. This is the
# performance/battery-first default because non-included apps never enter TUN.
SBMAGIC_PACKAGE_MODE=white

# DNS mode: real-ip is the hard per-app default. fake-ip is advanced only.
SBMAGIC_DNS_MODE=real-ip
SBMAGIC_DNS_STRATEGY=ipv4_only

# DNS servers use the sing-box 1.12+ server format (type + server), not the
# old "address: https://..." URL form. TYPE is one of: https (DoH), tls
# (DoT), quic (DoQ), h3 (DoH3), udp, tcp. SERVER should be an IP literal,
# not a hostname, URL, or host:port. For encrypted DNS, *_TLS_SERVER_NAME
# sets TLS SNI/certificate name (and DoH Host in sing-box) while still dialing
# the IP, so providers like dns.google or dns.quad9.net can work without a
# DNS bootstrap loop. local resolves direct (bootstrap/CN/direct domains);
# remote resolves through the proxy (everything else, no DNS leak). UDP is the
# default local bootstrap path to avoid stale encrypted-DNS idle connections
# delaying proxy node resolution after the device has been idle.
SBMAGIC_DNS_LOCAL_TYPE=udp
SBMAGIC_DNS_LOCAL_SERVER=223.5.5.5
SBMAGIC_DNS_LOCAL_TLS_SERVER_NAME=
SBMAGIC_DNS_REMOTE_TYPE=https
SBMAGIC_DNS_REMOTE_SERVER=1.1.1.1
SBMAGIC_DNS_REMOTE_TLS_SERVER_NAME=cloudflare-dns.com
SBMAGIC_DNS_FINAL=remote
# Keep IP->domain mapping from DNS answers so route geosite/domain rules still
# work in real-ip mode while sniffing stays off for lower first-connection cost.
SBMAGIC_DNS_REVERSE_MAPPING=true
SBMAGIC_FAKEIP4=198.18.0.0/15
SBMAGIC_FAKEIP6=fc00::/18

# Local control API. The secret is generated into runtime/api.env.
# The WebUI is the panel (module/webroot/); sing-box's own static
# dashboard server (external_ui) is intentionally not used.
# Bound to 127.0.0.1 only and protected by the generated secret. "auto"
# generates a random high port into runtime/api.env so casual localhost scans
# cannot rely on a stable default port. Set a numeric port only if you need one.
SBMAGIC_API_HOST=127.0.0.1
SBMAGIC_API_PORT=auto
SBMAGIC_API_FIREWALL=true
SBMAGIC_API_MODE=Rule

# Rule-set fallback/update interval. Packaged zips include local geosite/geoip
# .srs files so first boot does not download rules. The detour below is only
# used when local files are missing or when the user manually refreshes them.
# Keep direct unless that path cannot reach the rule-set host.
SBMAGIC_RULESET_DOWNLOAD_DETOUR=direct
SBMAGIC_RULE_UPDATE_INTERVAL=168h
SBMAGIC_UDP_TIMEOUT=5m

# Optional route sniffing (SNI/HTTP Host). Keep it off for lower first
# connection latency; DNS reverse mapping and geoip rules still carry most
# routing in real-ip mode. Enable only when domain routing misses traffic from
# apps that do not use the system DNS path.
SBMAGIC_SNIFF=false
SBMAGIC_SNIFF_TIMEOUT=100ms
