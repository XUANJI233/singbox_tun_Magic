# Runtime switches use explicit true/false values.
SBMAGIC_ENABLED=true
SBMAGIC_BOOT_START=false
SBMAGIC_WATCHDOG=true
SBMAGIC_WATCHDOG_INTERVAL=300

# TUN defaults: gvisor was the reliable Android CLI/root path in AVD tests.
SBMAGIC_STACK=gvisor
# Runtime binary basename. Change this if a target app keys off a known process
# name; allowed characters: A-Z a-z 0-9 . _ -
SBMAGIC_PROCESS_NAME=netd-helper
SBMAGIC_INTERFACE=utun0
SBMAGIC_MTU=1400
SBMAGIC_AUTO_ROUTE=true
SBMAGIC_STRICT_ROUTE=true

# Routing policy after an app has entered TUN.
# proxy: off | global | bypass-cn
# free-flow: off | global
# mixed priority applies to apps that are in neither packages.proxy nor
# packages.free-flow.
SBMAGIC_PROXY_RULE_MODE=bypass-cn
SBMAGIC_FREE_FLOW_RULE_MODE=off
SBMAGIC_MIXED_RULE_PRIORITY=proxy

# IPv6 leak protection: the tun always claims the IPv6 default route
# regardless of this switch (magicctl render_config), so disabling it
# does not mean "ignore IPv6" -- it means "block proxied apps' real
# IPv6 traffic instead of letting it bypass the proxy over the carrier
# network". Turning this on also requires changing SBMAGIC_DNS_STRATEGY
# away from ipv4_only (e.g. to prefer_ipv4) before AAAA records are
# actually resolved -- the WebUI settings tab explains this next to the
# toggle.
SBMAGIC_IPV6=false

# Package mode:
# black = proxy everything except packages listed in packages.exclude
# white = only proxy packages listed in packages.include
SBMAGIC_PACKAGE_MODE=black

# DNS mode: real-ip is the hard per-app default. fake-ip is advanced only.
SBMAGIC_DNS_MODE=real-ip
SBMAGIC_DNS_STRATEGY=ipv4_only

# DNS servers use the sing-box 1.12+ server format (type + server), not the
# old "address: https://..." URL form. TYPE is one of: https (DoH), tls
# (DoT), quic (DoQ), h3 (DoH3), udp, tcp. SERVER should be an IP literal --
# a hostname would itself need to be resolved first (domain_resolver), which
# we deliberately avoid here. local resolves direct (for CN/direct domains);
# remote resolves through the proxy (for everything else, no DNS leak).
SBMAGIC_DNS_LOCAL_TYPE=https
SBMAGIC_DNS_LOCAL_SERVER=223.5.5.5
SBMAGIC_DNS_REMOTE_TYPE=https
SBMAGIC_DNS_REMOTE_SERVER=1.1.1.1
SBMAGIC_DNS_FINAL=remote
SBMAGIC_FAKEIP4=198.18.0.0/15
SBMAGIC_FAKEIP6=fc00::/18

# Local control API. The secret is generated into runtime/api.env.
# The WebUI is the panel (module/webroot/); sing-box's own static
# dashboard server (external_ui) is intentionally not used.
# Bound to 127.0.0.1 only and protected by the generated secret. "auto"
# generates a random high port into runtime/api.env so casual localhost scans
# cannot rely on a stable default port. Set a numeric port only if you need one.
SBMAGIC_API_HOST=127.0.0.1
SBMAGIC_API_PORT=auto
SBMAGIC_API_FIREWALL=true
SBMAGIC_API_MODE=Rule

# Rule-set update interval. 168h = 7 days.
SBMAGIC_RULESET_DOWNLOAD_DETOUR=proxy
SBMAGIC_RULE_UPDATE_INTERVAL=168h
