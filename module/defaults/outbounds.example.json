[
  {
    "type": "selector",
    "tag": "proxy",
    "outbounds": [
      "my-node",
      "auto",
      "direct"
    ],
    "default": "my-node",
    "interrupt_exist_connections": true
  },
  {
    "type": "urltest",
    "tag": "auto",
    "outbounds": [
      "my-node"
    ],
    "url": "https://www.gstatic.com/generate_204",
    "interval": "3m",
    "idle_timeout": "30m",
    "tolerance": 50
  },
  {
    "type": "selector",
    "tag": "free-flow",
    "outbounds": [
      "free-flow-node",
      "direct"
    ]
  },
  {
    "type": "vless",
    "tag": "my-node",
    "server": "example.com",
    "server_port": 443,
    "uuid": "00000000-0000-0000-0000-000000000000",
    "tls": {
      "enabled": true,
      "server_name": "example.com",
      "utls": {
        "enabled": true,
        "fingerprint": "chrome"
      }
    },
    "transport": {
      "type": "xhttp",
      "host": "example.com",
      "path": "/CloudSync.DriveService.v2/update",
      "mode": "packet-up",
      "x_padding_bytes": "100-1000",
      "x_padding_obfs_mode": true,
      "x_padding_header": "X-Correlation-ID",
      "x_padding_placement": "header",
      "x_padding_method": "tokenish",
      "session_placement": "cookie",
      "session_key": "X-Request-TraceId",
      "seq_placement": "cookie",
      "seq_key": "X-Request-Seq",
      "sc_max_each_post_bytes": "1000000",
      "sc_min_posts_interval_ms": "30",
      "uplink_http_method": "POST"
    }
  },
  {
    "type": "vless",
    "tag": "free-flow-node",
    "server": "example.com",
    "server_port": 443,
    "uuid": "00000000-0000-0000-0000-000000000000",
    "tls": {
      "enabled": true,
      "server_name": "example.com",
      "utls": {
        "enabled": true,
        "fingerprint": "chrome"
      }
    },
    "transport": {
      "type": "grpc",
      "service_name": "free-flow"
    }
  },
  {
    "type": "direct",
    "tag": "direct"
  }
]
